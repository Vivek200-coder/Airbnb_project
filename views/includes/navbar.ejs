<style>
  .search-form {
    display: flex;
    align-items: center;
    background: white;
    border: 1.5px solid #ddd;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .search-form:focus-within {
    border-color: #fe424d;
    box-shadow: 0 4px 15px rgba(254, 66, 77, 0.2);
  }
  .search-form input {
    border: none;
    outline: none;
    padding: 0.55rem 1.2rem;
    font-size: 0.95rem;
    font-family: "Plus Jakarta Sans", sans-serif;
    background: transparent;
    width: 220px;
  }
  .search-form button {
    background-color: #fe424d;
    border: none;
    padding: 0.55rem 1.2rem;
    color: white;
    cursor: pointer;
    border-radius: 0 25px 25px 0;
    transition: background-color 0.2s;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .search-form button:hover {
    background-color: #d63a45;
  }

  .mobile-menu {
    padding: 1rem;
    border-top: 1px solid #eee;
  }
  .mobile-menu a {
    display: block;
    padding: 0.6rem 0;
    color: #222;
    text-decoration: none;
    font-size: 1rem;
    border-bottom: 1px solid #f5f5f5;
  }
  .mobile-menu a:hover {
    color: #fe424d;
  }
  .mobile-menu .search-form {
    margin-bottom: 1rem;
    width: 100%;
  }
  .mobile-menu .search-form input {
    width: 100%;
    flex: 1;
  }
</style>

<nav class="navbar bg-white border-bottom sticky-top">
  <div class="container-fluid px-3 d-flex align-items-center">

    <!-- Logo -->
    <a class="navbar-brand me-3" href="/listings">
      <i class="fa-sharp fa-regular fa-compass" style="color:#fe424d; font-size:2rem;"></i>
    </a>

    <!-- Explore desktop -->
    <a href="/listings" class="text-decoration-none text-dark me-2 d-none d-md-block">Explore</a>

    <!-- Search bar center desktop -->
    <form class="search-form mx-auto d-none d-md-flex" action="/listings" method="GET">
      <input type="search" name="search" placeholder="Search destination"/>
      <button type="submit">
        <i class="fa-solid fa-magnifying-glass"></i> Search
      </button>
    </form>

    <!-- Desktop right links -->
    <div class="d-none d-md-flex align-items-center gap-2 ms-3">
      <% if(currUser) { %>
        <a href="/listings/new" class="text-decoration-none text-dark">Airbnb your home</a>
        <a href="/logout" class="text-decoration-none"><b>Log out</b></a>
      <% } else { %>
        <a href="/listings/new" class="text-decoration-none text-dark">Airbnb your home</a>
        <a href="/signup" class="text-decoration-none"><b>Signup</b></a>
        <a href="/login" class="text-decoration-none"><b>Log in</b></a>
      <% } %>
    </div>

    <!-- Hamburger RIGHT side mobile only -->
    <button class="navbar-toggler ms-auto d-flex d-md-none"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mobileNav"
      aria-controls="mobileNav"
      aria-expanded="false">
      <span class="navbar-toggler-icon"></span>
    </button>

  </div>

  <!-- Mobile dropdown -->
  <div class="collapse d-md-none" id="mobileNav">
    <div class="mobile-menu">

      <!-- Mobile search -->
      <form class="search-form mb-3" action="/listings" method="GET">
        <input type="search" name="search" placeholder="Search destination" style="flex:1; width:auto;"/>
        <button type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <!-- Mobile links -->
      <a href="/listings">Explore</a>
      <a href="/listings/new">Airbnb your home</a>
      <% if(currUser) { %>
        <a href="/logout"><b>Log out</b></a>
      <% } else { %>
        <a href="/signup"><b>Signup</b></a>
        <a href="/login"><b>Log in</b></a>
      <% } %>

    </div>
  </div>

</nav>