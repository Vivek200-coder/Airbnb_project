<style>
  .search-form {
    display: flex;
    align-items: center;
    background: white;
    border: 1.5px solid #ddd;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .search-form:focus-within {
    border-color: #fe424d;
    box-shadow: 0 4px 15px rgba(254, 66, 77, 0.2);
  }
  .search-form input {
    border: none;
    outline: none;
    padding: 0.55rem 1.2rem;
    font-size: 0.95rem;
    flex: 1;
    font-family: "Plus Jakarta Sans", sans-serif;
    background: transparent;
    width: 220px;
  }
  .search-form button {
    background-color: #fe424d;
    border: none;
    padding: 0.55rem 1.2rem;
    color: white;
    cursor: pointer;
    border-radius: 0 25px 25px 0;
    transition: background-color 0.2s;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .search-form button:hover {
    background-color: #d63a45;
  }

  .nav-right a {
    color: #222 !important;
    text-decoration: none;
    padding: 0.4rem 0.6rem;
    font-size: 0.95rem;
  }
  .nav-right a:hover {
    color: #fe424d !important;
  }

  /* Mobile menu styling */
  .mobile-menu {
    border-top: 1px solid #eee;
    padding: 1rem 0;
  }
  .mobile-menu a {
    display: block;
    padding: 0.5rem 0;
    color: #222;
    text-decoration: none;
    font-size: 1rem;
  }
  .mobile-menu a:hover {
    color: #fe424d;
  }
  .mobile-menu .search-form {
    margin-bottom: 1rem;
  }
  .mobile-menu .search-form input {
    width: 100%;
  }
</style>

<nav class="navbar navbar-expand-md bg-white border-bottom sticky-top">
  <div class="container-fluid px-3">

    <!-- Logo -->
    <a class="navbar-brand me-3" href="/listings">
      <i class="fa-sharp fa-regular fa-compass" style="color:#fe424d; font-size:2rem;"></i>
    </a>

    <!-- Explore (desktop only) -->
    <a class="nav-link d-none d-md-block me-2" href="/listings" style="color:#222;">Explore</a>

    <!-- Search bar center (desktop only) -->
    <form class="search-form d-none d-md-flex mx-auto" action="/listings" method="GET">
      <input
        type="search"
        name="search"
        placeholder="Search destination"
      />
      <button type="submit">
        <i class="fa-solid fa-magnifying-glass"></i> Search
      </button>
    </form>

    <!-- Right links (desktop only) -->
    <div class="nav-right d-none d-md-flex align-items-center ms-3">
      <% if(currUser) { %>
        <a href="/listings/new">Airbnb your home</a>
        <a href="/logout"><b>Log out</b></a>
      <% } else { %>
        <a href="/listings/new">Airbnb your home</a>
        <a href="/signup"><b>Signup</b></a>
        <a href="/login"><b>Log in</b></a>
      <% } %>
    </div>

    <!-- Hamburger (mobile only - right side) -->
    <button class="navbar-toggler ms-auto d-md-none" type="button"
      data-bs-toggle="collapse"
      data-bs-target="#mobileMenu"
      aria-controls="mobileMenu"
      aria-expanded="false">
      <span class="navbar-toggler-icon"></span>
    </button>

  </div>

  <!-- Mobile dropdown menu -->
  <div class="collapse container-fluid" id="mobileMenu">
    <div class="mobile-menu">

      <!-- Mobile search -->
      <form class="search-form mb-3" action="/listings" method="GET">
        <input type="search" name="search" placeholder="Search destination"/>
        <button type="submit">
          <i class="fa-solid fa-magnifying-glass"></i> Search
        </button>
      </form>

      <!-- Mobile links -->
      <a href="/listings">Explore</a>
      <a href="/listings/new">Airbnb your home</a>
      <% if(currUser) { %>
        <a href="/logout"><b>Log out</b></a>
      <% } else { %>
        <a href="/signup"><b>Signup</b></a>
        <a href="/login"><b>Log in</b></a>
      <% } %>

    </div>
  </div>

</nav>