<% layout("/layouts/boilerplate") %>

<!-- Filters -->
<div id="filters">
  <a href="/listings<%= (typeof search !== 'undefined' && search) ? '?search=' + search : '' %>"
  class="filter <%= (typeof category === 'undefined' || !category) ? 'active' : '' %>">
  <div><i class="fa-solid fa-house"></i></div>
  <p>All</p>
</a>
  <a href="/listings?category=Trending<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Trending') ? 'active' : '' %>">
    <div><i class="fa-solid fa-fire"></i></div>
    <p>Trending</p>
  </a>
  <a href="/listings?category=Rooms<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Rooms') ? 'active' : '' %>">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </a>
  <a href="/listings?category=Iconic Cities<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Iconic Cities') ? 'active' : '' %>">
    <i class="fa-solid fa-mountain-city"></i>
    <p>Iconic Cities</p>
  </a>
  <a href="/listings?category=Mountains<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Mountains') ? 'active' : '' %>">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </a>
  <a href="/listings?category=Castles<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Castles') ? 'active' : '' %>">
    <i class="fa-solid fa-chess-rook"></i>
    <p>Castles</p>
  </a>
  <a href="/listings?category=Amazing Pools<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Amazing Pools') ? 'active' : '' %>">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Amazing Pools</p>
  </a>
  <a href="/listings?category=Camping<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Camping') ? 'active' : '' %>">
    <i class="fa-solid fa-tent"></i>
    <p>Camping</p>
  </a>
  <a href="/listings?category=Farms<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Farms') ? 'active' : '' %>">
    <i class="fa-solid fa-tractor"></i>
    <p>Farms</p>
  </a>
  <a href="/listings?category=Domes<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Domes') ? 'active' : '' %>">
    <i class="fa-solid fa-landmark-dome"></i>
    <p>Domes</p>
  </a>
  <a href="/listings?category=Boat<%= (typeof search !== 'undefined' && search) ? '&search=' + search : '' %>"
    class="filter <%= (typeof category !== 'undefined' && category === 'Boat') ? 'active' : '' %>">
    <i class="fa-solid fa-ship"></i>
    <p>Boat</p>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<!-- Listings Grid -->
<% if (allListings.length === 0) { %>
  <div class="no-results">
    <i class="fa-solid fa-magnifying-glass"></i>
    <h4>No listings found</h4>
    <p>Try searching something else or <a href="/listings" style="color:#fe424d">view all listings</a></p>
  </div>
<% } else { %>
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings) { %>
      <div class="col">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card listing-card border-0">
            <img
              src="<%= listing.image.url %>"
              class="card-img-top"
              alt="listing_image"
            >
            <div class="card-body px-0">
              <p class="card-text">
                <b><%= listing.title %></b><br>
                <span style="color:#666; font-size:0.9rem;">
                  <%= listing.location %>, <%= listing.country %>
                </span><br>
                &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> /night
                <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>
      </div>
    <% } %>
  </div>
<% } %>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for(let info of taxInfo) {
      if(info.style.display != "inline") {
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>